# Copy this file to .env and fill in the values.
# .env is gitignored; .env.example is the committed template.

# SQLAlchemy connection string.
# Local default:
DATABASE_URL=sqlite:///./data/house_rules.db
# Supabase example (later):
# DATABASE_URL=postgresql+psycopg://user:pw@host:5432/db

# bcrypt hash of the parent PIN. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'1234', bcrypt.gensalt()).decode())"
PARENT_PIN_HASH=
